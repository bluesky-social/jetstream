{
  "lexicon": 1,
  "id": "network.bsky.jetstream.listSegments",
  "defs": {
    "main": {
      "type": "query",
      "description": "Enumerate sealed segment files available for download, in ascending index order.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000,
            "default": 100,
            "description": "Maximum number of segments to return."
          },
          "cursor": {
            "type": "string",
            "description": "Opaque pagination cursor from a previous response."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["segments"],
          "properties": {
            "cursor": { "type": "string" },
            "segments": {
              "type": "array",
              "items": { "type": "ref", "ref": "#segment" }
            }
          }
        }
      }
    },
    "segment": {
      "type": "object",
      "required": ["name", "index", "sizeBytes", "checksum", "eventCount", "minSeq", "maxSeq", "minIndexedAt", "maxIndexedAt"],
      "properties": {
        "name": { "type": "string", "description": "Segment filename; pass to getSegment." },
        "index": { "type": "integer", "description": "Zero-based segment index." },
        "sizeBytes": { "type": "integer", "description": "File size in bytes." },
        "checksum": { "type": "string", "description": "Segment-format xxh3 metadata checksum as 16-char hex; equals the getSegment ETag." },
        "eventCount": { "type": "integer", "description": "Number of events in the segment." },
        "minSeq": { "type": "integer" },
        "maxSeq": { "type": "integer" },
        "minIndexedAt": { "type": "integer", "description": "Earliest indexed-at, unix microseconds." },
        "maxIndexedAt": { "type": "integer", "description": "Latest indexed-at, unix microseconds." }
      }
    }
  }
}
