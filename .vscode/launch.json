{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Jetstream (simulator)",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/jetstream",
			"cwd": "${workspaceFolder}",
			"args": [
				"serve"
			],
			"env": {
				"JETSTREAM_RELAY_URL": "http://localhost:7777",
				"JETSTREAM_PLC_URL": "http://localhost:7777"
			}
		},
		{
			"name": "Debug Jetstream (prod)",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/jetstream",
			"cwd": "${workspaceFolder}",
			"args": [
				"serve",
				"--max-backfill-repos=40"
			]
		}
	]
}
