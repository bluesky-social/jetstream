{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug Jetstream (simulator)",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/jetstream",
			"cwd": "${workspaceFolder}",
			"env": {
				"JETSTREAM_DISABLE_REPO_ACTION_RATE_LIMITS": "true"
			},
			"args": [
				"serve",
				"--relay-url=http://localhost:7777",
				"--plc-url=http://localhost:7777",
				"--data-dir=${workspaceFolder}/data-sim",
			]
		},
		{
			"name": "Debug Jetstream (prod)",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/jetstream",
			"cwd": "${workspaceFolder}",
			"env": {
				"JETSTREAM_DISABLE_REPO_ACTION_RATE_LIMITS": "true"
			},
			"args": [
				"serve",
				"--max-backfill-repos=20",
				"--data-dir=${workspaceFolder}/data-prod",
			]
		}
	]
}
