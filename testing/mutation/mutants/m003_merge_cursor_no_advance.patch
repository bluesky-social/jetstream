+++ b/internal/ingest/orchestrator/merge_runner.go
@@ -86,7 +86,7 @@ func (r *mergeRunner) run(ctx context.Context) error {
 			if err := r.simulateCrash(ctx, crashpoint.AfterMergeDstFlushBeforeSourceCommit); err != nil {
 				return err
 			}
-			if err := commitSourceComplete(r.store, r.cache, sf.Idx+1, perDID, r.now()); err != nil {
+			if err := commitSourceComplete(r.store, r.cache, sf.Idx, perDID, r.now()); err != nil {
 				return err
 			}
 			r.metrics.incMergeSegmentsConsumed()
