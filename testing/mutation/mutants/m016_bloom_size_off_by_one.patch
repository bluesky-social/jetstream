index d97c361..e04a9c7 100644
--- a/segment/bloom.go
+++ b/segment/bloom.go
@@ -88,7 +88,7 @@ func encodeBlockBloomsRegion(filters []*gloom.Filter) ([]byte, uint32, error) {
 
 	le := binary.LittleEndian
 	le.PutUint32(header[0:4], uint32(len(filters)))
-	le.PutUint32(header[4:8], sizeBytes)
+	le.PutUint32(header[4:8], sizeBytes-1)
 
 	return append(header, body...), sizeBytes, nil
