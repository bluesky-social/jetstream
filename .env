# Dev-only defaults that point jetstream at the local simulator
# (cmd/simulator). `just run` and any other recipe with `set
# dotenv-load` picks these up automatically. `just run-prod`
# overrides them inline.
#
# Do not put secrets in this file — it is checked in.
JETSTREAM_RELAY_URL=http://localhost:7777
JETSTREAM_PLC_URL=http://localhost:7777

# Make /status feel live during local development. Production
# leaves this at the 30s default to amortize pebble scans.
JETSTREAM_STATUS_CACHE_TTL=1s
